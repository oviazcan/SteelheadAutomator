{
  "manifest_version": 3,
  "name": "Steelhead Automator — iPad",
  "description": "Mejoras de Steelhead para iPad (bundle de applets empaquetado). Mini-bundle de validación del pipeline.",
  "version": "0.1.0",
  "host_permissions": [
    "https://app.gosteelhead.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://app.gosteelhead.com/*"
      ],
      "js": [
        "main-bundle.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
