{
  "manifest_version": 3,
  "name": "Candado de Surtido — Steelhead (iPad)",
  "description": "Bloquea mover piezas NO programadas en Preparación de Surtido. POC Safari/iPadOS del applet surtido-guard.",
  "version": "0.1.0",
  "host_permissions": [
    "https://app.gosteelhead.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.gosteelhead.com/*"],
      "js": ["surtido-guard-core.js", "surtido-guard.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
