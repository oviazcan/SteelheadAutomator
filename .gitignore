# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# Python (caches de pytest / bytecode)
__pycache__/
.pytest_cache/
*.pyc

# IDE
.vscode/
.idea/
*.code-workspace

# Build
*.zip

# Secrets
.env

# Scan results (contain Steelhead invoice tokens)
scan_results_*.json

# Capturas de tráfico GraphQL para diseño de applets (pueden traer datos productivos)
surtido-guard-capture*.json

# Capturas HTML de la SPA (dumps "Guardar como" con datos de clientes), mal ubicadas
# en vbas/ (esa carpeta es para fuentes .bas de VBA, no HTML).
vbas/*.html

# Validador de hashes — resultados diarios (ruido, no aportan al repo)
tools/.hash-validation/

# hash-autopilot — resultados diarios + estado del browser headless (no versionar)
tools/.hash-autopilot/
tools/hash-autopilot/.browser-state/
tools/hash-autopilot/.state/

# Excel temp lock files
~$*.xlsm
~$*.xlsx
Plantilla_Cotizaciones_y_NP_v84_2.xlsm

# Scratch payloads locales (samples de GraphQL/factura, etc.)
/json

# Estado de herramientas (Claude Code, plugin superpowers) — nunca versionar
.claude/
.superpowers/

# config.json en la RAÍZ es una copia stale; el config real vive en remote/config.json
/config.json

# Insumos de análisis sueltos en la raíz (no son código del proyecto).
# NOTA: NO usar *.xlsm/*.xlsx global — eso ignoraría remote/templates/Plantilla_Cotizaciones_v11.xlsm (plantilla oficial).
/1._Proceso - Tratamientos Genericos.xlsx
/Problema de negocio*

# Payloads de API capturados desde DevTools (referencia local, no versionar)
docs/api/Payload: *.txt

# Datos efímeros de corridas de recuperación de CustomInputs
/tools/27_*.json
/tools/snapshot_ci_*.json

# Migración one-time de customInputs (snapshots/resume con data de PNs)
tools/.fix-custominputs/

# Proyecto Xcode generado por el converter de Safari (artefacto de build, no source).
# El source versionado es safari/extension/ ; safari/xcode/ se regenera con el converter.
safari/xcode/
